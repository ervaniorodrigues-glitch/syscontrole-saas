# ============================================================
# SYSCONTROLE SAAS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Tipo de banco: 'sqlite' (local) ou 'postgres' (produção)
DB_TYPE=postgres

# Porta do servidor
PORT=3000

# ---- PostgreSQL (Supabase) ----
PG_HOST=db.xxxxxxxxxxxx.supabase.co
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=sua_senha_aqui
PG_DATABASE=postgres

# ---- Ou use a URL completa (alternativa) ----
# DATABASE_URL=postgresql://postgres:senha@db.xxxx.supabase.co:5432/postgres

# ---- Ambiente ----
NODE_ENV=production
